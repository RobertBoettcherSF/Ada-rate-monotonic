project Tests is
   -- Test project for Rate_Monotonic package
   -- This project compiles and runs the comprehensive test suite
   
   for Source_Dirs use ("..", ".");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   
   -- Main program is the test suite
   for Main use ("rate_monotonic_tests.adb");

   package Compiler is
      -- Use Ada 2012, optimize, and enable all warnings
      for Default_Switches ("Ada") use ("-O2", "-gnat12", "-gnatwa");
   end Compiler;

   package Linker is
      -- Link with necessary libraries
      for Default_Switches ("Ada") use ("-static");
   end Linker;
end Tests;
