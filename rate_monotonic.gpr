project Rate_Monotonic is
   -- Define the source and object directories
   for Source_Dirs use (".");
   for Object_Dir use "obj";
   
   -- Configured as a library since this is a scheduling analysis package
   for Main use (); 

   package Compiler is
      -- Use Ada 2012, optimize, and enable all warnings
      for Default_Switches ("Ada") use ("-O2", "-gnat12", "-gnatwa");
   end Compiler;
end Rate_Monotonic;
